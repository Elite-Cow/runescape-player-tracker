# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# MongoDB Atlas connection string
# Find this in Atlas → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/runescape_stats?retryWrites=true&w=majority

# Optional: local dev port for the Express API (defaults to 3001)
PORT=3001
